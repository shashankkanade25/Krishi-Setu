<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us | KrishiSetu</title>
    <%- include('partials/seo') %>
    <link rel="stylesheet" href="/css/landing.css">
    <style>
        .contact-container { max-width: 800px; margin: 4rem auto; padding: 0 1rem; text-align: center; line-height: 1.6; }
        .contact-container h1 { color: #2e7d32; margin-bottom: 2rem; }
        .contact-info { display: flex; flex-direction: column; gap: 1.5rem; align-items: center; margin-top: 2rem; }
        .contact-item { font-size: 1.2rem; }
        .contact-icon { color: #4CAF50; margin-right: 0.5rem; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="contact-container">
        <h1>Contact Us</h1>
        <p>Have questions about joining our farmer-to-industry platform or ordering fresh produce? We're here to help.</p>
        
        <div class="contact-info">
            <div class="contact-item">
                <i class="fas fa-envelope contact-icon"></i> support@krishisetu.com
            </div>
            <div class="contact-item">
                <i class="fas fa-phone contact-icon"></i> +91 98765 43210
            </div>
            <div class="contact-item">
                <i class="fas fa-map-marker-alt contact-icon"></i> Pune, Maharashtra, India
            </div>
        </div>
    </div>
    <%- include('partials/footer') %>
</body>
</html>
